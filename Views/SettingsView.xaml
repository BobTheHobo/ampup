<UserControl x:Class="AmpUp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="20,12,20,18">

            <!-- ── CONNECTION ──────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="CONNECTION" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>

                    <!-- Status indicators -->
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock Text="Turn Up"
                                       Width="96"
                                       Style="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0" />
                            <Ellipse x:Name="ConnectionDot" Width="8" Height="8"
                                     Fill="#FF4444" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtConnectionStatus"
                                       Text="Disconnected"
                                       Style="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center" Margin="0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="TreasLin N3"
                                       Width="96"
                                       Style="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0" />
                            <Ellipse x:Name="N3ConnectionDot" Width="8" Height="8"
                                     Fill="#FF4444" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtN3ConnectionStatus"
                                       Text="Not detected"
                                       Style="{StaticResource SecondaryText}"
                                       VerticalAlignment="Center" Margin="0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Port selector row -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Hardware Mode" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"
                                   ToolTip="Choose whether Amp Up listens to Turn Up, Stream Controller, or both at once" />
                        <controls:SegmentedControl x:Name="SegHardwareMode"
                                                   HorizontalAlignment="Left"
                                                   MinWidth="360"
                                                   Margin="0,0,0,10" />
                        <StackPanel x:Name="ActiveSurfacePanel" Visibility="Collapsed" Margin="0,4,0,10">
                            <TextBlock Text="Active Surface" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"
                                       ToolTip="Which surface drives the Mixer, Buttons, and Lights tabs when both devices are available" />
                            <controls:SegmentedControl x:Name="SegActiveSurface"
                                                       HorizontalAlignment="Left"
                                                       MinWidth="360" />
                        </StackPanel>

                        <StackPanel Margin="0,4,0,10">
                            <TextBlock x:Name="TxtN3IdleSleepLabel" Text="Stream Controller Screen Sleep: 10m"
                                       Style="{StaticResource SecondaryText}" Margin="0,0,0,6"
                                       ToolTip="Blank the N3 LCD screens after this long with no keyboard/mouse activity. Drag to Never to keep them lit." />
                            <StackPanel Orientation="Horizontal">
                                <controls:StyledSlider x:Name="SldN3IdleSleep"
                                                       Minimum="0" Maximum="11"
                                                       Width="360"
                                                       Step="1"
                                                       ShowLabel="False"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center" />
                                <ui:Button x:Name="BtnN3SleepNow" Content="Sleep Now"
                                           Appearance="Secondary" Margin="10,0,0,0" Height="34"
                                           VerticalAlignment="Center"
                                           ToolTip="Blank the N3 screens right now. Any keyboard/mouse input wakes them back up." />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Device Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"
                                   ToolTip="Select the COM port for your AmpUp hardware" />
                        <StackPanel Orientation="Horizontal">
                            <controls:ListPicker x:Name="CmbSerialPort" Width="220"
                                      VerticalAlignment="Center"
                                      ToolTip="Available COM ports — select the one for your AmpUp hardware" />
                            <ui:Button x:Name="BtnRefreshPorts" Content="Refresh"
                                       Appearance="Secondary" Margin="8,0,0,0" Height="38"
                                       ToolTip="Rescan for available COM ports" />
                            <ui:Button x:Name="BtnAutoDetect" Content="Auto-Detect"
                                       Appearance="Primary" Margin="8,0,0,0" Height="38"
                                       ToolTip="Automatically find the AmpUp hardware by probing available ports" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Advanced toggle -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,4,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Cursor="Hand" Margin="0,0,0,0"
                                        x:Name="AdvancedToggle" MouseLeftButtonDown="AdvancedToggle_Click">
                                <TextBlock x:Name="AdvancedArrow" Text="▶" FontSize="9"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Advanced" Style="{StaticResource SecondaryText}"
                                           VerticalAlignment="Center" Margin="0" />
                            </StackPanel>

                            <StackPanel x:Name="AdvancedSection" Visibility="Collapsed" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Serial Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                   ToolTip="COM port for the AmpUp hardware (e.g. COM3)" />
                                        <ui:TextBox x:Name="TxtSerialPort" Width="160"
                                                    PlaceholderText="COM3"
                                                    Background="{DynamicResource InputBgBrush}"
                                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ToolTip="COM port for the AmpUp hardware (e.g. COM3)" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Baud Rate" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                   ToolTip="Communication speed — leave at 115200" />
                                        <ui:TextBox x:Name="TxtBaudRate" Width="160"
                                                    PlaceholderText="115200"
                                                    Background="{DynamicResource InputBgBrush}"
                                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ToolTip="Communication speed — leave at 115200" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── STARTUP ─────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="GENERAL" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <CheckBox x:Name="ChkStartWithWindows"
                              Content="Start with Windows"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalContentAlignment="Center"
                              ToolTip="Launch Amp Up automatically when you log in" />
                    <CheckBox x:Name="ChkAutoSuggestLayout"
                              Content="Auto-suggest knob layout"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalContentAlignment="Center"
                              Margin="0,6,0,0"
                              ToolTip="Show a banner in Mixer when known apps are detected and knobs are unassigned" />

                </StackPanel>
            </Border>

            <!-- ── APPEARANCE ────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="APPEARANCE" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Accent Color" Style="{StaticResource SecondaryText}" Margin="0,0,0,8"
                               ToolTip="App-wide theme color — affects headers, LEDs, and highlights" />
                    <WrapPanel x:Name="AccentSwatches" Orientation="Horizontal" />
                    <TextBlock Text="Card Theme" Style="{StaticResource SecondaryText}" Margin="0,12,0,8"
                               ToolTip="Background and card color tint — changes the overall mood of the app" />
                    <WrapPanel x:Name="CardThemeSwatches" Orientation="Horizontal" />
                </StackPanel>
            </Border>

            <!-- ── PROFILES ────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="PROFILES" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Active Profile" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                       ToolTip="The currently loaded profile" />
                            <controls:ListPicker x:Name="CmbProfiles" Width="200"
                                      ToolTip="Select a profile to load or manage" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnSaveProfile" Content="Save"
                                           Appearance="Primary" Margin="0,0,6,0"
                                           ToolTip="Save current settings to this profile" />
                                <ui:Button x:Name="BtnLoadProfile" Content="Load"
                                           Appearance="Secondary" Margin="0,0,6,0"
                                           ToolTip="Load the selected profile" />
                                <ui:Button x:Name="BtnEditProfile" Content="Edit"
                                           Appearance="Secondary" Margin="0,0,6,0"
                                           ToolTip="Edit profile name, icon, and color" />
                                <ui:Button x:Name="BtnNewProfile" Content="New"
                                           Appearance="Secondary" Margin="0,0,6,0"
                                           ToolTip="Create a new profile from current settings" />
                                <ui:Button x:Name="BtnDeleteProfile" Content="Delete"
                                           Appearance="Danger" Margin="0,0,6,0"
                                           ToolTip="Delete the selected profile (cannot be undone)" />
                                <ui:Button x:Name="BtnOverview" Content="Overview"
                                           Appearance="Secondary"
                                           ToolTip="View all knob and button assignments across profiles" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Export / Import profile files -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Profile files"
                                       Style="{StaticResource SecondaryText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnExportProfile" Content="Export Profile"
                                           Appearance="Secondary" Margin="0,0,8,0"
                                           ToolTip="Save the current profile as a .json file" />
                                <ui:Button x:Name="BtnImportProfile" Content="Import Profile"
                                           Appearance="Secondary"
                                           ToolTip="Load a profile from a .json file" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Import from Turn Up -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Turn Up import"
                                       Style="{StaticResource SecondaryText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <ui:Button x:Name="BtnImportTurnUp" Content="Import from Turn Up"
                                       Appearance="Secondary" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- BACKUP & RESTORE -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="BACKUP &amp; RESTORE" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="BtnBackupSettings" Content="Backup Settings"
                                   Appearance="Secondary" Margin="0,0,8,0"
                                   ToolTip="Save a full Amp Up settings backup file" />
                        <ui:Button x:Name="BtnRestoreSettings" Content="Restore Settings"
                                   Appearance="Danger"
                                   ToolTip="Restore app settings and profiles from a backup file" />
                    </StackPanel>
                    <TextBlock Text="Backups include tokens/API keys."
                               Style="{StaticResource SecondaryText}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- LED Calibration moved to the Lights tab (CALIBRATION sub-tab) -->

            <!-- ── INTEGRATIONS ────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="INTEGRATIONS" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>

                    <!-- Home Assistant -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Home Assistant" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <Ellipse x:Name="HaStatusDotHeader" Width="8" Height="8"
                                     Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <TextBlock x:Name="TxtHaStatusHeader" Text="Disabled"
                                       Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                        </StackPanel>
                        <CheckBox x:Name="ChkHaEnabled"
                                  Content="Enabled"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="URL" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <ui:TextBox x:Name="TxtHaUrl" Width="320"
                                            PlaceholderText="http://homeassistant.local:8123"
                                            Background="{DynamicResource InputBgBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Token" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <PasswordBox x:Name="TxtHaToken" Width="320"
                                             Background="{DynamicResource InputBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ui:Button x:Name="BtnHaTest" Content="Test Connection"
                                       Appearance="Secondary" Height="32" />
                            <ui:Button x:Name="BtnHaRefresh" Content="Refresh Entities"
                                       Appearance="Secondary" Height="32" Margin="6,0,0,0" />
                            <Ellipse x:Name="HaStatusDot" Width="8" Height="8"
                                     Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <TextBlock x:Name="TxtHaStatus" Text=""
                                       Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- OBS Studio -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="OBS Studio" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="ObsStatusDotHeader" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtObsStatusHeader" Text="Disabled"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <CheckBox x:Name="ChkObsEnabled"
                                      Content="Enabled"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Host" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="TxtObsHost" Width="220"
                                                PlaceholderText="localhost"
                                                Background="{DynamicResource InputBgBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="TxtObsPort" Width="100"
                                                PlaceholderText="4455"
                                                Background="{DynamicResource InputBgBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Password" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <PasswordBox x:Name="TxtObsPassword" Width="220"
                                                 Background="{DynamicResource InputBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <ui:Button x:Name="BtnObsTest" Content="Test Connection"
                                           Appearance="Secondary" Height="32" />
                                <Ellipse x:Name="ObsStatusDot" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtObsStatus" Text=""
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Govee -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Govee" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <!-- LAN + Cloud side-by-side -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- LAN Column -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox x:Name="ChkGoveeEnabled"
                                                  Content="Enable Govee LAN sync"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Margin="0,0,16,0" />
                                        <Ellipse x:Name="GoveeStatusDot" Width="8" Height="8"
                                                 Fill="#555555" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock x:Name="TxtGoveeStatus" Text="Disabled"
                                                   Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel x:Name="GoveeLanSection" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <ui:Button x:Name="BtnGoveeScan" Content="Scan Network"
                                                       Appearance="Secondary" Height="32" />
                                            <ui:Button x:Name="BtnGoveeLanHelp" Content="?"
                                                       Appearance="Secondary" Width="32" Height="32"
                                                       Margin="6,0,0,0"
                                                       ToolTip="Not finding devices? Click for help" />
                                            <ui:Button x:Name="BtnGoveeRestoreRemoved" Content="Restore Removed"
                                                       Appearance="Secondary" Height="32"
                                                       Margin="6,0,0,0"
                                                       Visibility="Collapsed"
                                                       ToolTip="Allow removed Govee devices to appear on scans again" />
                                            <TextBlock x:Name="TxtGoveeScanStatus" Text=""
                                                       Style="{StaticResource SecondaryText}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </StackPanel>
                                        <StackPanel x:Name="GoveeDeviceList" Margin="0,0,0,8" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Vertical separator -->
                                <Border Grid.Column="1" Width="1" Background="{DynamicResource CardBorderBrush}"
                                        Margin="16,0,16,0" />

                                <!-- Cloud API Column -->
                                <StackPanel Grid.Column="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox x:Name="ChkGoveeCloudEnabled"
                                                  Content="Enable Govee Cloud API"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Margin="0,0,16,0" />
                                        <Ellipse x:Name="GoveeCloudStatusDot" Width="8" Height="8"
                                                 Fill="#555555" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock x:Name="TxtGoveeCloudStatus" Text="Disabled"
                                                   Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel x:Name="GoveeCloudSection" Visibility="Collapsed">
                                        <TextBlock Text="API Key" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                   ToolTip="Enables scenes and music mode control" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <PasswordBox x:Name="TxtGoveeApiKey" Width="320"
                                                         Background="{DynamicResource InputBgBrush}"
                                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}" />
                                            <ui:Button x:Name="BtnGoveeSetupGuide" Content="Setup Guide"
                                                       Appearance="Secondary" Margin="8,0,0,0" Height="32" />
                                        </StackPanel>
                                        <TextBlock x:Name="TxtGoveeApiStatus" Text=""
                                                   Style="{StaticResource SecondaryText}" FontSize="11"
                                                   Margin="0,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Hint about Ambience tab -->
                            <TextBlock x:Name="TxtGoveeAmbienceHint" Text=""
                                       Style="{StaticResource SecondaryText}" FontSize="11"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- VoiceMeeter -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="VoiceMeeter" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="VmStatusDotHeader" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtVmStatusHeader" Text="Disabled"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <CheckBox x:Name="ChkVmEnabled"
                                      Content="Enabled"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,4" />
                        </StackPanel>
                    </Border>

                    <!-- Corsair iCUE -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Corsair iCUE" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="CorsairStatusDot" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtCorsairStatus" Text="Disabled"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <CheckBox x:Name="ChkCorsairEnabled"
                                      Content="Enabled"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,4" />
                            <StackPanel x:Name="CorsairDeviceList" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- SignalRGB -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="SignalRGB" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="SignalRgbStatusDot" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtSignalRgbStatus" Text="Disabled"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <CheckBox x:Name="ChkSignalRgbEnabled"
                                      Content="Enabled"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <StackPanel Margin="0,0,12,0" Visibility="Collapsed">
                                    <TextBlock Text="Bridge Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="TxtSignalRgbPort" Width="120"
                                                PlaceholderText="45333"
                                                Background="{DynamicResource InputBgBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Layout" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="CmbSignalRgbCanvasShape" Width="160" Height="32"
                                              Background="{DynamicResource InputBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}">
                                        <ComboBoxItem Content="Classic Strip" />
                                        <ComboBoxItem Content="Knob Grid" />
                                        <ComboBoxItem Content="Arc" />
                                        <ComboBoxItem Content="Matrix" />
                                        <ComboBoxItem Content="Wide Strip" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <ui:Button x:Name="BtnSignalRgbInstallPlugin" Content="Update Plugin"
                                               Appearance="Secondary" Height="32" Margin="0,0,6,0" />
                                    <ui:Button x:Name="BtnSignalRgbOpenPluginFolder" Content="Open Folder"
                                               Appearance="Secondary" Height="32" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Ignored Lights"
                                       Style="{StaticResource SecondaryText}" Margin="0,8,0,4" />
                            <WrapPanel Margin="0,0,0,4">
                                <CheckBox x:Name="ChkSignalRgbIgnoreKnob1" Content="Light 1"
                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,22,0" />
                                <CheckBox x:Name="ChkSignalRgbIgnoreKnob2" Content="Light 2"
                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,22,0" />
                                <CheckBox x:Name="ChkSignalRgbIgnoreKnob3" Content="Light 3"
                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,22,0" />
                                <CheckBox x:Name="ChkSignalRgbIgnoreKnob4" Content="Light 4"
                                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,22,0" />
                                <CheckBox x:Name="ChkSignalRgbIgnoreKnob5" Content="Light 5"
                                          Foreground="{StaticResource TextPrimaryBrush}" />
                            </WrapPanel>
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                                    Margin="0,10,0,0" Padding="0,10,0,0">
                                <StackPanel>
                                    <CheckBox x:Name="ChkSignalRgbProfileSync"
                                              Content="Sync AmpUp profiles to SignalRGB"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              Margin="0,0,0,8" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Profile" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                            <controls:ListPicker x:Name="CmbSignalRgbProfile" Width="150"
                                                                 Height="32"
                                                                 Background="{DynamicResource InputBgBrush}"
                                                                 BorderBrush="{DynamicResource InputBorderBrush}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Effect" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                            <ui:TextBox x:Name="TxtSignalRgbProfileEffect" Width="190"
                                                        PlaceholderText="SignalRGB effect name"
                                                        Background="{DynamicResource InputBgBrush}"
                                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Layout" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                            <ui:TextBox x:Name="TxtSignalRgbProfileLayout" Width="190"
                                                        PlaceholderText="Optional layout name"
                                                        Background="{DynamicResource InputBgBrush}"
                                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button x:Name="BtnSignalRgbApplyProfileSync" Content="Apply Now"
                                                   Appearance="Secondary" Height="30" Margin="0,0,8,0" />
                                        <TextBlock x:Name="TxtSignalRgbProfileSyncHint" Text=""
                                                   Style="{StaticResource SecondaryText}" FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="TxtSignalRgbPluginStatus" Text=""
                                       Style="{StaticResource SecondaryText}" FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Discord -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Discord" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="DiscordStatusDot" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtDiscordStatus" Text="Not connected"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnDiscordConnect" Content="Connect"
                                           Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:Button x:Name="BtnDiscordDisconnect" Content="Disconnect"
                                           Appearance="Secondary" IsEnabled="False" />
                            </StackPanel>
                            <TextBlock Text="Discord must be running."
                                       Style="{StaticResource SecondaryText}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Spotify -->
                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,10,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Spotify" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <Ellipse x:Name="SpotifyStatusDot" Width="8" Height="8"
                                         Fill="#555555" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBlock x:Name="TxtSpotifyStatus" Text="Not connected"
                                           Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Playback, likes, shuffle, LCD album art."
                                       Style="{StaticResource SecondaryText}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <ui:Button x:Name="BtnSpotifySetupGuide" Content="Setup Guide"
                                           Appearance="Primary" Margin="0,0,8,0" />
                                <ui:Button x:Name="BtnSpotifyConnect" Content="Connect"
                                           Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:Button x:Name="BtnSpotifyDisconnect" Content="Disconnect"
                                           Appearance="Secondary" IsEnabled="False" />
                            </StackPanel>
                            <Expander Header="Advanced — paste a Client ID directly"
                                      Foreground="{DynamicResource TextDimBrush}"
                                      Margin="0,4,0,0" FontSize="11">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Client ID" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <TextBox x:Name="TxtSpotifyClientId"
                                             Background="{DynamicResource InputBgBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             Padding="8,4" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── ABOUT ─────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="ABOUT" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtVersion" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                        <ui:Button x:Name="BtnCheckUpdate" Content="Check for Updates"
                                   Appearance="Secondary" Margin="16,0,0,0" />
                    </StackPanel>
                    <TextBlock x:Name="TxtUpdateStatus" Style="{StaticResource SecondaryText}" Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

        <!-- ── STATIC FOOTER — Buy Me a Coffee ────────────────── -->
        <Border Grid.Row="1" CornerRadius="20" Margin="0,8,0,4" Padding="16,8,20,8"
                Cursor="Hand" HorizontalAlignment="Center" x:Name="CoffeeFooter"
                Background="#2A2A2A" BorderBrush="#3A3A3A" BorderThickness="1"
                ToolTip="buymeacoffee.com/audioslayer" Opacity="0.85">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="♥" Foreground="#FF4466" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="Buy me a coffee" FontSize="13" FontWeight="SemiBold"
                           Foreground="#CCCCCC" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
